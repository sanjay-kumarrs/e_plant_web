# ==============================================================================
# Git Ignore Configuration
# ==============================================================================

# Dependencies
node_modules/
jspm_packages/
web_modules/

# Production Build Outputs
dist/
dist-ssr/
build/
out/
.next/

# Logs and Debug files
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment and Local Config files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.local

# OS Metadata
.DS_Store
Thumbs.db
desktop.ini

# IDE, Editor, and Tool Settings
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swo
*.swp
.project
.classpath
.settings/

# Testing and Coverage
coverage/
*.lcov
.nyc_output/

# Application Specific / User Uploaded Files
# Ignores all uploaded plant images but keeps the uploads directory folder structure
plant-back/uploads/*
!plant-back/uploads/.gitkeep
